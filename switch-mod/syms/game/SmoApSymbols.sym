// CreditsStartHook (Strategy A): patches the BL @+0x4C54A4 inside
// StaffRollScene::init to call our onCreditsStart, which then chain-calls
// the original target — al::Scene::initDrawSystemInfo. Sail needs to
// resolve initDrawSystemInfo so our callback can reach it.
_ZN2al5Scene18initDrawSystemInfoERKNS_13SceneInitInfoE

// Talkatoo% mode (Phase 3): substitution at the speech-resolve chokepoint.
// GameDataFunction::tryFindShineMessage(actor*, sys*, world_id, index)
// returns the per-shine display char16_t* for the speech bubble. We
// trampoline it and replace the return value with an AP-pool moon name
// when the caller is a Poetter (Talkatoo) actor.
_ZN16GameDataFunction19tryFindShineMessageEPKN2al9LiveActorEPKNS0_17IUseMessageSystemEii

// Poetter (Talkatoo) primary vtable. Read at install time via
// hk::ro::lookupSymbol — used as a range filter to scope substitution to
// Talkatoo-only callsites. The trampoline above runs for every caller
// (cutscenes, pause menu, hint UI), so without this we'd substitute moon
// names project-wide.
_ZTV7Poetter

// 2026-05-23: rs::calcShineIndexTableNameAvailable and rs::tryUnlockShineName
// were briefly added to this catalog as candidate hook targets for the
// Talkatoo% "No more hints" fix. Both froze SMO's init thread inside
// HkTrampoline::installAtSym — the symbols are inlined into Poetter::exeWait
// and not exported in main.nso, so sail's fakelib stub resolved to a bogus
// address. Removed. The shipped fix is the force-false strategy on the
// already-hooked `_ZNK12GameDataFile15isOpenShineNameEii` (see
// switch-mod/src/hooks/TalkatooMenuMarkHook.cpp).

// --- ImGui debug overlay deps (ui::ApDebugConsole) ----------------------
// Application::sInstance is the SEAD_SINGLETON_DISPOSER static that
// Application::instance() reads. al::getStationedHeap is the stationed
// heap source the overlay carves a 2 MiB ExpHeap out of. sead::ExpHeap::create
// + sead::SafeStringBase<char>::operator= are needed by the ExpHeap
// constructor (it stores the heap name as a SafeString). All taken from
// Kgamer77/SMOO-Plus-Hakkun's working syms.
_ZN11Application9sInstanceE
_ZN2al16getStationedHeapEv
_ZN4sead7ExpHeap6createEmRKNS_14SafeStringBaseIcEEPNS_4HeapEiNS5_13HeapDirectionEb
_ZN4sead14SafeStringBaseIcEaSERKS1_

// Talkatoo% pause-menu mark fix — TalkatooMenuMarkHook.cpp.
//
// Hook 1: GameDataFile::isOpenShineName(s32 world_id, s32 index) const.
// Pause-menu Power Moon list queries this to draw the "name revealed"
// indicator. In Talkatoo% mode we OR-in our AP-pool named set so the
// moons we substituted in the speech bubble are marked as named in the
// menu (vanilla path keeps marking collected / achievement-revealed
// moons; we add our AP picks on top).
//
// Hook 2: GameDataFile::tryUnlockShineName(s32 world_id, s32 index).
// Talkatoo's vanilla picker writes the per-(world, idx) "name revealed"
// state via this setter. In Talkatoo% mode we suppress the write so the
// menu doesn't mark moons the player never actually heard Talkatoo speak.
//
// Helper: GameDataFile::findShine(s32 world_id, s32 index) const →
// HintInfo*. Used by Hook 1 to translate (world_id, idx) into the
// stageName/objId pair shineUidByStageObj resolves to a shine_uid.
_ZNK12GameDataFile15isOpenShineNameEii
_ZN12GameDataFile18tryUnlockShineNameEii
_ZNK12GameDataFile9findShineEii

// OdysseyRescue — Lost + Ruined Kingdom softlock prevention.
//
// In our randomizer the player can rush into Lost (wrecked-Odyssey state) or
// Ruined (boss-attacked state) without having received enough kingdom-specific
// moon AP credits to release the Odyssey, and neither kingdom permits
// backtracking — permanent softlock. Mirrors Kgamer77/SuperMarioOdysseyArchipelago
// v1.2's updatePlayerInfo() fix: per-frame sweep that calls repairHome /
// unlockWorld whenever isCrashHome or isBossAttackedHome holds.
//
// All 10 manglings produced via aarch64-none-elf-g++ on forward-decls matching
// MonsterDruide1/OdysseyDecomp src/System/GameDataFunction.h. The unlockWorld
// name was already in the project pre-c85a27b cleanup and resurrected with
// its original mangling.
_ZN16GameDataFunction11isCrashHomeE22GameDataHolderAccessor
_ZN16GameDataFunction10repairHomeE20GameDataHolderWriter
_ZN16GameDataFunction9crashHomeE20GameDataHolderWriter
_ZN16GameDataFunction11unlockWorldE20GameDataHolderWriteri
_ZN16GameDataFunction18isBossAttackedHomeE22GameDataHolderAccessor
_ZN16GameDataFunction23repairHomeByCrashedBossE20GameDataHolderWriter
_ZN16GameDataFunction25isRepairHomeByCrashedBossE22GameDataHolderAccessor
_ZN16GameDataFunction18getWorldIndexClashEv
_ZN16GameDataFunction16getWorldIndexSkyEv
_ZN16GameDataFunction19getCurrentStageNameE22GameDataHolderAccessor

// GrowSeedInstantHook: rs::getGrowFlowerTime(const al::LiveActor*,
// const al::PlacementId*). The public rs:: wrapper around
// GameDataFile::getGrowFlowerTime — the direct GameDataFile method is
// inlined in 1.0.0 main.nso and not in dynsym, but this wrapper IS
// (cross-checked against MrKatzenGaming/BTT-Studio syms/game/System/
// GameDataUtil.sym which pins it at 0x004dd230). Trampolined to return
// 1 for planted pots (orig==0 passes through), making (now - returned)
// enormous in any timebase so the pot blooms on next stage re-entry.
// NOT the same as BTT-Studio's "Refresh Seeds" toggle, which returns
// 0 from this wrapper as a deliberate RESET (clears the planted state +
// the seed item). See hooks/GrowSeedInstantHook.cpp.
_ZN2rs17getGrowFlowerTimeEPKN2al9LiveActorEPKNS0_11PlacementIdE
