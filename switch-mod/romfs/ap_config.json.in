{
  "_comment": "Generated by CMake from romfs/ap_config.json.in. Override defaults via -DBRIDGE_HOST=... -DBRIDGE_PORT=... at configure time. Editing this file directly on the SD card also works, but a re-install will overwrite it with the cmake-configured values.",
  "_path_on_sd": "sd:/atmosphere/contents/0100000000010000/romfs/ap_config.json",
  "bridge_host": "@BRIDGE_HOST@",
  "bridge_port": @BRIDGE_PORT@,
  "retry_ms": @BRIDGE_RETRY_MS@,
  "tcp_recv_timeout_ms": @BRIDGE_RECV_TIMEOUT_MS@,
  "log_level": "@BRIDGE_LOG_LEVEL@"
}
